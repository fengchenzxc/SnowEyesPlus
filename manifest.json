{
  "manifest_version": 3,

  "name": "SnowEyesPlus",
  "version": "1.0.0",
  "description": "SnowEyesPlus: 信息收集+DOMXSS检测+报告生成",

  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },

  "permissions": [
    "activeTab",    
    "scripting",    
    "storage",
    "webRequest",
    "cookies",
    "tabs",
    "webNavigation"
  ],

  "host_permissions": [
    "*://*/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["report-schema-core.js", "fingerprint-core.js", "content.js"],
      "run_at": "document_end",
      "all_frames": true
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "logo.png",
      "32": "logo.png",
      "48": "logo.png",
      "128": "logo.png"
    },
    "default_badge_text": "0",
    "default_badge_background_color": "#666666"
  },

  "web_accessible_resources": [{
    "resources": [
      "finger.json",
      "kscan_fingerprint.json",
      "webapp.json",
      "apps.json",
      "snow_x25.js",
      "*.map"
    ],
    "matches": ["*://*/*"]
  }]
}
